// Template for the gitignored GoogleConfig.swift.
// Copy this to GoogleConfig.swift and paste your Google Cloud "Desktop app"
// OAuth client credentials, then rebuild. End users only ever see a "Connect"
// button — these values are baked into the app.
import Foundation

enum GoogleConfig {
    static let clientID = "YOUR_CLIENT_ID.apps.googleusercontent.com"
    static let clientSecret = "YOUR_CLIENT_SECRET"

    static var isConfigured: Bool { !clientID.isEmpty && !clientSecret.isEmpty }
}
